-- LeetCode 183: Customers Who Never Order

-- Customers Table
-- +----+-------+
-- | id | name  |
-- +----+-------+
-- | 1  | Joe   |
-- | 2  | Henry |
-- | 3  | Sam   |
-- | 4  | Max   |
-- +----+-------+

-- Orders Table
-- +----+------------+
-- | id | customerId |
-- +----+------------+
-- | 1  | 3          |
-- | 2  | 1          |
-- +----+------------+

-- Approach:
-- Use LEFT JOIN to keep all customers.
-- Customers with no matching order will have NULL values.

SELECT c.name AS Customers
FROM Customers c
LEFT JOIN Orders o
ON c.id=o.customerID
WHERE o.customerID IS NUll;
